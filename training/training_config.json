{
  "max_steps": 300,
  "total_batch_size": 8192,
  "seq_len": 128,
  "sample_every": 50,
  "sampler": {
    "prompts": [
      {
        "prompt": "Hello",
        "max_tokens": 48,
        "temperature": 0.7,
        "top_k": 20
      },
      {
        "prompt": "Hello, I'm a language model",
        "max_tokens": 64,
        "temperature": 0.6,
        "top_k": 40
      },
      {
        "prompt": "The",
        "max_tokens": 48,
        "temperature": 0.8,
        "top_k": 40
      },
      {
        "prompt": "Once upon a time",
        "max_tokens": 64,
        "temperature": 0.8,
        "top_k": 60
      },
      {
        "prompt": "Today",
        "max_tokens": 48,
        "temperature": 0.7,
        "top_k": 40
      },
      {
        "prompt": "I",
        "max_tokens": 48,
        "temperature": 0.7,
        "top_k": 40
      }
    ]
  },
  "save_every": 1000,
  "optimizer": {
    "lr": 0.0003,
    "weight_decay": 0.1,
    "betas": [0.9, 0.95],
    "eps": 1e-8
  },
  "lr_scheduler": {
    "type": "sequential",
    "schedulers": [
      {
        "type": "linear",
        "steps": 50,
        "start_factor": 0.1,
        "end_factor": 1.0
      },
      {
        "type": "cosine_annealing",
        "steps": 250,
        "eta_min": 1e-5
      }
    ]
  }
}
