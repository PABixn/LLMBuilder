{
  "max_steps": 100,
  "total_batch_size": 32768,
  "micro_batch_size": null,
  "seq_len": 1024,
  "sample_every": 10,
  "sampler": {
    "prompts": [
      {
        "prompt": "First Citizen:",
        "max_tokens": 48,
        "temperature": 0.7,
        "top_k": 20
      },
      {
        "prompt": "The",
        "max_tokens": 48,
        "temperature": 0.8,
        "top_k": 40
      },
      {
        "prompt": "I",
        "max_tokens": 48,
        "temperature": 0.7,
        "top_k": 40
      },
      {
        "prompt": "All:",
        "max_tokens": 64,
        "temperature": 0.7,
        "top_k": 40
      }
    ]
  },
  "save_every": 500,
  "optimizer": {
    "lr": 0.002,
    "weight_decay": 0.0,
    "betas": [
      0.9,
      0.95
    ],
    "eps": 1e-08
  },
  "lr_scheduler": {
    "type": "sequential",
    "schedulers": [
      {
        "type": "linear",
        "steps": 8,
        "start_factor": 0.1,
        "end_factor": 1.0
      },
      {
        "type": "cosine_annealing",
        "steps": 92,
        "eta_min": 9e-05
      }
    ]
  }
}
