LLM_STUDIO_HOST=127.0.0.1
LLM_STUDIO_PORT=8000
LLM_STUDIO_DATA_DIR=./data
LLM_STUDIO_PROJECTS_DIR=projects
LLM_STUDIO_WEB_DIST_DIR=./web-dist
LLM_STUDIO_SERVE_WEB=1

# Comma-separated list. Leave blank to use defaults.
LLM_STUDIO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LLM_STUDIO_CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1)(:\d+)?

# Optional: require this header for API routes: X-LLM-Studio-Token
LLM_STUDIO_RUNTIME_TOKEN=

LLM_STUDIO_LOG_LEVEL=info
LLM_STUDIO_ACCESS_LOG=0
