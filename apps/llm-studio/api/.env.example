LLM_STUDIO_HOST=127.0.0.1
LLM_STUDIO_PORT=8000
LLM_STUDIO_DATA_DIR=./data
LLM_STUDIO_PROJECTS_DIR=projects
LLM_STUDIO_WEB_DIST_DIR=./web-dist
LLM_STUDIO_SERVE_WEB=1

# Tokenizer workspace storage/runtime (all optional).
# Relative values resolve from LLM_STUDIO_DATA_DIR.
# Leave unset to use the repo-local default: apps/llm-studio/api/artifacts/tokenizers
# LLM_STUDIO_TOKENIZER_OUTPUT_DIR=
# Leave unset to use the repo-local default: apps/llm-studio/api/datasets/uploads
# LLM_STUDIO_TOKENIZER_UPLOAD_DIR=
LLM_STUDIO_TOKENIZER_DB_PATH=db/tokenizer_studio.db
LLM_STUDIO_TOKENIZER_LOG_DIR=logs
LLM_STUDIO_TOKENIZER_HF_HOME=cache/huggingface
LLM_STUDIO_TOKENIZER_HF_DATASETS_CACHE=cache/huggingface/datasets
LLM_STUDIO_TOKENIZER_MAX_WORKERS=1
# LLM_STUDIO_TOKENIZER_DATABASE_URL=sqlite:////absolute/path/to/tokenizer_studio.db

# Comma-separated list. Leave blank to use defaults.
LLM_STUDIO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LLM_STUDIO_CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1)(:\d+)?

# Optional: require this header for API routes.
# Accepted headers: X-Studio-Token, X-LLM-Studio-Token, X-Tokenizer-Studio-Token
LLM_STUDIO_RUNTIME_TOKEN=

# RunPod pod training. The API key can also be pasted into the UI for the
# current API process; it is not written to job metadata.
# LLM_STUDIO_RUNPOD_API_KEY=
LLM_STUDIO_RUNPOD_DEFAULT_GPU_TYPE=NVIDIA GeForce RTX 4090
LLM_STUDIO_RUNPOD_DEFAULT_GPU_COUNT=1
LLM_STUDIO_RUNPOD_DEFAULT_CLOUD_TYPE=SECURE
# LLM_STUDIO_RUNPOD_DEFAULT_DATA_CENTER_ID=
LLM_STUDIO_RUNPOD_DEFAULT_VOLUME_SIZE_GB=100
LLM_STUDIO_RUNPOD_CONTAINER_DISK_GB=50
LLM_STUDIO_RUNPOD_VOLUME_MOUNT_PATH=/workspace
LLM_STUDIO_RUNPOD_TRAINING_IMAGE=ghcr.io/pabixn/llm-builder-training:latest
LLM_STUDIO_RUNPOD_AGENT_PORT=8021
LLM_STUDIO_RUNPOD_AGENT_PORT_PROTOCOL=tcp
LLM_STUDIO_RUNPOD_POD_TTL_MINUTES=0
LLM_STUDIO_RUNPOD_AUTO_DELETE_POD=1
LLM_STUDIO_RUNPOD_AUTO_DELETE_VOLUME=0

LLM_STUDIO_LOG_LEVEL=info
LLM_STUDIO_ACCESS_LOG=0
